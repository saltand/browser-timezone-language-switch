{
  "name": "browser-timezone-language-switch",
  "description": "manifest.json description",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
