    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "bumpp": "^11.0.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.20"
  }
}
